# XREAL Backup Server Configuration
# Copy this to .env and customize

# API key for authentication (change this!)
XREAL_API_KEY=your-secret-api-key-here

# Database file path
XREAL_DB_PATH=/home/deck/xreal-backup/backup.db

# Server bind address (0.0.0.0 = accept from all interfaces)
XREAL_HOST=0.0.0.0

# Server port
XREAL_PORT=8090
