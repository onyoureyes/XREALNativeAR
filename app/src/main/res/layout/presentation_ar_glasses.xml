<?xml version="1.0" encoding="utf-8"?>
<!--
    AR 안경 Presentation 레이아웃 (XREAL Light 1920x1080)

    검정(#000000) = 웨이브가이드에서 완전 투명 → 현실 세계 보임
    밝은 색상 = 부유하는 AR 오버레이로 표시됨

    OverlayView는 전체 DrawingCommand 시스템을 지원 (Text, Rect, Circle, Line 등)
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:keepScreenOn="true">

    <!--
        AR 안경 전용 OverlayView — 메인 화면의 OverlayView와 동일한 DrawingCommand 수신.
        MainActivity.onDrawingCommand() → arGlassesPresentation.applyDrawCommand() 포워딩.
    -->
    <com.xreal.nativear.OverlayView
        android:id="@+id/arGlassesOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</FrameLayout>
