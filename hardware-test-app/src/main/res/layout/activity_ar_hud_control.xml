<?xml version="1.0" encoding="utf-8"?>
<!-- Phone-side control panel for AR HUD (not mirrored to Nreal Light) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#1A1A2E">

    <TextView
        android:id="@+id/tvPhoneStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="AR HUD Control Panel"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:padding="12dp" />

    <Button
        android:id="@+id/btnHudConnect"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Connect Nreal Light"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/btnHudStartCam"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Start SLAM Camera"
        android:backgroundTint="#2E7D32"
        android:textColor="#FFFFFF"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/tvPhoneLog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text=""
        android:textColor="#AAAAAA"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:padding="8dp"
        android:layout_marginTop="12dp"
        android:background="#0D0D1A"
        android:scrollbars="vertical" />

</LinearLayout>
