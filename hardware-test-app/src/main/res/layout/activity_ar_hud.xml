<?xml version="1.0" encoding="utf-8"?>
<!-- AR HUD Layout: Pure black background = transparent on Nreal Light waveguide -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/hudRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:keepScreenOn="true">

    <!-- Center crosshair / focus indicator -->
    <View
        android:id="@+id/crosshair"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="center"
        android:background="@drawable/crosshair_ring" />

    <!-- Center label (OCR result appears here) -->
    <TextView
        android:id="@+id/tvCenterLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="40dp"
        android:text=""
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:shadowColor="#000000"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="4"
        android:visibility="gone" />

    <!-- Top-left status info -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="24dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="XREAL AR"
            android:textColor="#88FFFFFF"
            android:textSize="14sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/tvFps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#6600FF88"
            android:textSize="12sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- Bottom-center info bar -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="32dp"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:id="@+id/tvOrientation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="R:0° P:0° Y:0°"
            android:textColor="#6600AAFF"
            android:textSize="12sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- Anchored labels container (dynamically added) -->
    <FrameLayout
        android:id="@+id/anchorContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</FrameLayout>
